# Auto-install dependencies
def check_and_install_deps():
    """Check and install missing dependencies"""
    # Check for ffmpeg
    if not shutil.which('ffmpeg'):
        print("Installing ffmpeg...")
        subprocess.run(['sudo', 'apt-get', 'install', '-y', 'ffmpeg'], check=False)

    # Check for Pillow
    try:
        from PIL import Image
    except ImportError:
        print("Installing Pillow...")
        subprocess.run([sys.executable, '-m', 'pip', 'install', 'pillow'], check=False)

check_and_install_deps()

# ANSI color codes
BOLD = '\033[1m'
CYAN = '\033[96m'
GREEN = '\033[92m'
YELLOW = '\033[93m'
RED = '\033[91m'
MAGENTA = '\033[95m'
RESET = '\033[0m'
CLEAR = '\033[2J\033[H'

# ASCII chars from darkest to lightest
ASCII_CHARS = ['@', '#', 'S', '%', '?', '*', '+', ';', ':', ',', '.']
# Color gradient for each character
ASCII_COLORS = [
    '\033[90m',  # dark gray
    '\033[37m',  # light gray
    '\033[97m',  # white
    '\033[36m',  # cyan
    '\033[35m',  # magenta
    '\033[34m',  # blue
    '\033[33m',  # yellow
    '\033[32m',  # green
    '\033[31m',  # red
    '\033[33m',  # yellow
    '\033[37m',  # white
]
RESET = '\033[0m'

def search_youtube(query):
    """Search YouTube and return results"""
    print(f"\n{YELLOW}🔍 Searching for: {query}{RESET}\n")
    try:
        result = subprocess.run(
            ['yt-dlp', '-j', '--flat-playlist', f'ytsearch10:{query}'],
            capture_output=True,
            text=True,
            timeout=10
        )

        if result.returncode != 0:
            print(f"{RED}Error searching: {result.stderr}{RESET}")
            return []

        videos = []
        for line in result.stdout.strip().split('\n'):
            if line:
                try:
                    videos.append(json.loads(line))
                except json.JSONDecodeError:
                    continue
        return videos
    except Exception as e:
        print(f"{RED}Search failed: {e}{RESET}")
        return []

def display_results(videos):
    """Display search results with colors"""
    if not videos:
        print(f"{RED}No results found{RESET}")
        return None

    print(f"{BOLD}{CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━{RESET}")
    for i, video in enumerate(videos, 1):
        title = video.get('title', 'Unknown')
        url = video.get('url', '')
        duration = video.get('duration', 0)

        if duration:
            mins, secs = divmod(duration, 60)
            duration_str = f"{int(mins)}:{int(secs):02d}"
        else:
            duration_str = "LIVE"

        print(f"{GREEN}{i:2d}.{RESET} {BOLD}{title[:60]}{RESET}")
        print(f"    {MAGENTA}Duration: {duration_str}{RESET} | {CYAN}{url}{RESET}\n")

    print(f"{BOLD}{CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━{RESET}\n")

    while True:
        try:
            choice = input(f"{YELLOW}Select video (1-{len(videos)}) or 'q' to quit: {RESET}").strip()
            if choice.lower() == 'q':
                return None
            choice = int(choice)
            if 1 <= choice <= len(videos):
                return videos[choice - 1]
            else:
                print(f"{RED}Invalid choice{RESET}")
        except ValueError:
            print(f"{RED}Please enter a number{RESET}")

def resize_image(image, new_width=100):
    """Resize image for ASCII display"""
    from PIL import Image
    width, height = image.size
    ratio = height / width / 1.65
    new_height = int(new_width * ratio)
    return image.resize((new_width, new_height))

def grayscale(image):
    """Convert to grayscale"""
    return image.convert("L")

def pixels_to_ascii(image):
    """Convert grayscale pixels to ASCII"""
    pixels = image.getdata()
    ascii_str = ""
    for pixel in pixels:
        ascii_str += ASCII_CHARS[pixel // 25]
    return ascii_str

def colorize_ascii(ascii_str):
    """Add colors to ASCII string"""
    colored = ""
    for char in ascii_str:
        if char in ASCII_CHARS:
            idx = ASCII_CHARS.index(char)
            colored += ASCII_COLORS[idx] + char + RESET
        else:
            colored += char
    return colored

def get_terminal_width():
    """Get usable terminal width (minimum 50 for readable ASCII)"""
    try:
        import os
        width = os.get_terminal_size().columns
        return max(width, 50)  # Minimum 50 chars for readable ASCII art
    except:
        return 80

def frame_to_ascii(frame_path, width=None):
    """Convert a single frame to ASCII art with colors"""
    try:
        from PIL import Image
        if width is None:
            width = get_terminal_width() - 2
        image = Image.open(frame_path)
        image = resize_image(image, width)
        image = grayscale(image)
        ascii_str = pixels_to_ascii(image)
        ascii_str = colorize_ascii(ascii_str)

        img_width = image.width
        ascii_str_len = len(ascii_str)
        ascii_img = ""
        for i in range(0, ascii_str_len, img_width):
            ascii_img += ascii_str[i:i+img_width] + "\n"
        return ascii_img
    except Exception as e:
        return f"Error: {e}"

def play_audio_only(video):
    """Play audio only (for narrow terminals)"""
    url = video.get('url', '')
    title = video.get('title', 'Video')

    if not url:
        print(f"{RED}No URL found{RESET}")
        return

    print(f"\n{GREEN}🎵 Playing audio: {title}{RESET}\n")
    try:
        process = subprocess.Popen(
            ['yt-dlp', '-f', 'bestaudio', '-o', '-', url],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL
        )
        subprocess.run(['mpv', '--no-video', '-'], stdin=process.stdout, check=False)
        process.stdout.close()
    except FileNotFoundError:
        print(f"{RED}yt-dlp or mpv not found{RESET}")
    except KeyboardInterrupt:
        print(f"\n{YELLOW}Playback stopped{RESET}")

def play_audio_only_file(video_path):
    """Play audio from cached video file"""
    print(f"\n{GREEN}🎵 Playing audio...{RESET}\n")
    try:
        subprocess.run(['mpv', '--no-video', video_path], check=False)
    except FileNotFoundError:
        print(f"{RED}mpv not found{RESET}")
    except KeyboardInterrupt:
        print(f"\n{YELLOW}Playback stopped{RESET}")

def play_from_cache(video_path):
    """Play cached video"""
    frames_dir = os.path.dirname(video_path) + '/frames'

    if not os.path.exists(frames_dir):
        print(f"{YELLOW}Converting to ASCII...{RESET}")
        os.makedirs(frames_dir, exist_ok=True)
        try:
            subprocess.run(
                ['ffmpeg', '-i', video_path, '-vf', 'fps=5', f'{frames_dir}/frame_%04d.png'],
                capture_output=True,
                timeout=120
            )
        except Exception as e:
            print(f"{RED}Error: {e}{RESET}")
            return

    frames = sorted([f for f in os.listdir(frames_dir) if f.endswith('.png')])
    if not frames:
        print(f"{RED}No frames found{RESET}")
        return

    print(f"{GREEN}Playing {len(frames)} frames with audio...{RESET}\n")
    print(f"{YELLOW}Press Ctrl+C to stop{RESET}\n")

    # Start audio playback in background
    audio_process = subprocess.Popen(
        ['mpv', '--no-video', video_path],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL
    )

    try:
        for i, frame in enumerate(frames):
            print(CLEAR, end='')
            frame_path = os.path.join(frames_dir, frame)
            ascii_art = frame_to_ascii(frame_path)
            print(f"[{i+1}/{len(frames)}]")
            print(ascii_art)
            time.sleep(0.2)
    except KeyboardInterrupt:
        print(f"\n{YELLOW}Playback stopped{RESET}")
    finally:
        audio_process.terminate()

def play_ascii_video(video):
    """Play video as ASCII art and cache it"""
    url = video.get('url', '')
    title = video.get('title', 'Video')

    if not url:
        print(f"{RED}No URL found{RESET}")
        return

    print(f"\n{GREEN}▶ Downloading: {title}{RESET}\n")

    # Create cache entry
    cache_dir = get_cache_dir()
    video_key = url.split('=')[-1][:11]
    cache_path = os.path.join(cache_dir, video_key)
    os.makedirs(cache_path, exist_ok=True)

    # Save metadata
    meta_file = os.path.join(cache_path, 'metadata.txt')
    with open(meta_file, 'w') as f:
        f.write(title)

    video_path = os.path.join(cache_path, 'video.mp4')
    frames_dir = os.path.join(cache_path, 'frames')
    os.makedirs(frames_dir, exist_ok=True)

    # Download video
    try:
        result = subprocess.run(
            ['yt-dlp', '-f', 'worst', '-o', video_path, url],
            capture_output=True,
            timeout=60
        )
        if result.returncode != 0:
            print(f"{RED}Download failed{RESET}")
            return
    except Exception as e:
        print(f"{RED}Download error: {e}{RESET}")
        return

    # Extract frames
    print(f"{YELLOW}🎬 Extracting frames...{RESET}")
    try:
        subprocess.run(
            ['ffmpeg', '-i', video_path, '-vf', 'fps=5', f'{frames_dir}/frame_%04d.png'],
            capture_output=True,
            timeout=120
        )
    except FileNotFoundError:
        print(f"{RED}ffmpeg not found. Install with: sudo apt-get install ffmpeg python3-pil{RESET}")
        return

    # Play frames
    frames = sorted([f for f in os.listdir(frames_dir) if f.endswith('.png')])
    if not frames:
        print(f"{RED}No frames extracted{RESET}")
        return

    print(f"{GREEN}Playing {len(frames)} frames with audio...{RESET}\n")
    print(f"{YELLOW}Press Ctrl+C to stop{RESET}\n")

    # Start audio playback in background
    audio_process = subprocess.Popen(
        ['mpv', '--no-video', video_path],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL
    )

    try:
        for i, frame in enumerate(frames):
            print(CLEAR, end='')
            frame_path = os.path.join(frames_dir, frame)
            ascii_art = frame_to_ascii(frame_path)
            print(f"[{i+1}/{len(frames)}]")
            print(ascii_art)
            time.sleep(0.2)
    except KeyboardInterrupt:
        print(f"\n{YELLOW}Playback stopped{RESET}")
    finally:
        audio_process.terminate()

def get_cache_dir():
    """Get or create cache directory"""
    cache_dir = os.path.expanduser('~/.youtube-ascii-cache')
    os.makedirs(cache_dir, exist_ok=True)
    return cache_dir

def list_cached_videos():
    """List all cached videos"""
    cache_dir = get_cache_dir()
    cached = {}
    for item in os.listdir(cache_dir):
        item_path = os.path.join(cache_dir, item)
        if os.path.isdir(item_path):
            # Read metadata if it exists
            meta_file = os.path.join(item_path, 'metadata.txt')
            if os.path.exists(meta_file):
                with open(meta_file, 'r') as f:
                    title = f.read().strip()
                cached[item] = title
    return cached

def show_main_menu():
    """Show main menu"""
    cached = list_cached_videos()

    try:
        term_width = os.get_terminal_size().columns
    except:
        term_width = 80

    print(f"\n{BOLD}{MAGENTA}╔════════════════════════════════════════╗{RESET}")
    print(f"{BOLD}{MAGENTA}║   {CYAN}YouTube ASCII Video Player{MAGENTA}   ║{RESET}")
    print(f"{BOLD}{MAGENTA}╚════════════════════════════════════════╝{RESET}\n")

    if term_width < 30:
        print(f"{YELLOW}⚠ Terminal too narrow ({term_width}ch) for ASCII art{RESET}\n")

    if cached:
        print(f"{GREEN}📹 Cached Videos:{RESET}\n")
        for i, (key, title) in enumerate(cached.items(), 1):
            print(f"{CYAN}{i}.{RESET} {title}")
        print()

    print(f"{YELLOW}s{RESET} - Search new video")
    if term_width < 30:
        print(f"{YELLOW}a{RESET} - Audio only mode")
    print(f"{YELLOW}c{RESET} - Clear cache")
    if cached:
        print(f"{YELLOW}1-{len(cached)}{RESET} - Play cached video")
    print()

    choice = input(f"{YELLOW}Choose option: {RESET}").strip().lower()
    return choice, cached, term_width

def main():
    if len(sys.argv) > 1:
        query = ' '.join(sys.argv[1:])
        videos = search_youtube(query)
        if not videos:
            return
        video = display_results(videos)
        if video:
            play_ascii_video(video)
    else:
        while True:
            choice, cached, term_width = show_main_menu()

            if choice == 's':
                query = input(f"\n{YELLOW}Search YouTube: {RESET}").strip()
                if query:
                    videos = search_youtube(query)
                    if videos:
                        video = display_results(videos)
                        if video:
                            if term_width < 30:
                                print(f"\n{YELLOW}(a)udio or (v)ideo? {RESET}", end='')
                                mode = input().strip().lower()
                                if mode == 'a':
                                    play_audio_only(video)
                                else:
                                    play_ascii_video(video)
                            else:
                                play_ascii_video(video)
            elif choice == 'a':
                query = input(f"\n{YELLOW}Search YouTube: {RESET}").strip()
                if query:
                    videos = search_youtube(query)
                    if videos:
                        video = display_results(videos)
                        if video:
                            play_audio_only(video)
            elif choice == 'c':
                import shutil
                cache_dir = get_cache_dir()
                shutil.rmtree(cache_dir)
                os.makedirs(cache_dir, exist_ok=True)
                print(f"{GREEN}✓ Cache cleared{RESET}")
            elif choice.isdigit():
                idx = int(choice)
                cached_list = list(cached.items())
                if 1 <= idx <= len(cached_list):
                    video_key, title = cached_list[idx - 1]
                    video_path = os.path.join(get_cache_dir(), video_key, 'video.mp4')
                    if os.path.exists(video_path):
                        print(f"\n{GREEN}▶ Playing: {title}{RESET}\n")
                        if term_width < 30:
                            print(f"{YELLOW}(a)udio or (v)ideo? {RESET}", end='')
                            mode = input().strip().lower()
                            if mode == 'a':
                                play_audio_only_file(video_path)
                            else:
                                play_from_cache(video_path)
                        else:
                            play_from_cache(video_path)
                else:
                    print(f"{RED}Invalid choice{RESET}")
            elif choice.lower() == 'q':
                break

if __name__ == '__main__':
    main()
