def get_terminal_width():
    """Get fixed terminal width"""
    return 80

def get_terminal_height():
    """Get full terminal height"""
    try:
        import os
        return os.get_terminal_size().lines - 1
    except:
        return 24

def resize_image(image, new_width=100, new_height=None):
    """Resize image for ASCII display to match terminal"""
    from PIL import Image
    width, height = image.size
    original_ratio = width / height

    char_ratio = 1.65
    new_height = int(new_width / original_ratio * char_ratio)

    return image.resize((new_width, new_height))

def grayscale(image):
    """Convert to grayscale"""
    return image.convert("L")

def pixels_to_ascii(image):
    """Convert grayscale pixels to ASCII (plain chars)"""
    pixels = image.getdata()
    ascii_str = ""
    for pixel in pixels:
        ascii_str += ASCII_CHARS[pixel // 25]
    return ascii_str

def pixels_to_ascii_with_colors(image):
    """Convert image pixels to ASCII with color info"""
    if image.mode != 'RGB':
        image = image.convert('RGB')

    pixels = list(image.getdata())
    gray_image = image.convert('L')
    gray_pixels = gray_image.getdata()

    result = []
    for i, (rgb, gray) in enumerate(zip(pixels, gray_pixels)):
        r, g, b = rgb
        char_idx = gray // 25
        char = ASCII_CHARS[char_idx]
        result.append((char, (r, g, b)))
    return result

def frame_to_ascii(frame_path, width=None, height=None):
    """Convert a single frame to ASCII art with optional colors"""
    try:
        from PIL import Image
        if width is None:
            width = get_terminal_width()
        if height is None:
            height = get_terminal_height()

        image = Image.open(frame_path)
        image = resize_image(image, width, height)

        # Apply enhancement for better text clarity
        if SETTINGS['enhance']:
            image = enhance_image(image)

        img_width = image.width
        ascii_img = ""

        if SETTINGS['color']:
            char_color_pairs = pixels_to_ascii_with_colors(image)
            for i in range(0, len(char_color_pairs), img_width):
                line_chars = char_color_pairs[i:i+img_width]
                line = ""
                for char, (r, g, b) in line_chars:
                    color = rgb_to_ansi(r, g, b)
                    line += color + char + RESET
                ascii_img += line + "\n"
        else:
            image = image.convert('L')
            ascii_str = pixels_to_ascii(image)
            for i in range(0, len(ascii_str), img_width):
                ascii_img += ascii_str[i:i+img_width] + "\n"

        return ascii_img
    except Exception as e:
        return f"Error: {e}"

def play_audio_only(video):
    """Play audio only (for narrow terminals)"""
    url = video.get('url', '')
    title = video.get('title', 'Video')

    if not url:
        print(f"{RED}No URL found{RESET}")
        return

    print(f"\n{GREEN}🎵 Playing audio: {title}{RESET}\n")
    try:
        process = subprocess.Popen(
            ['yt-dlp', '-f', 'bestaudio', '-o', '-', url],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL
        )
        subprocess.run(['mpv', '--no-video', '-'], stdin=process.stdout, check=False)
        process.stdout.close()
    except FileNotFoundError:
        print(f"{RED}yt-dlp or mpv not found{RESET}")
    except KeyboardInterrupt:
        print(f"\n{YELLOW}Playback stopped{RESET}")

def play_audio_only_file(video_path):
    """Play audio from cached video file"""
    print(f"\n{GREEN}🎵 Playing audio...{RESET}\n")
    try:
        subprocess.run(['mpv', '--no-video', video_path], check=False)
    except FileNotFoundError:
        print(f"{RED}mpv not found{RESET}")
    except KeyboardInterrupt:
        print(f"\n{YELLOW}Playback stopped{RESET}")

def play_from_cache(video_path):
    """Play cached video with audio"""
    frames_dir = os.path.dirname(video_path) + '/frames'

    if not os.path.exists(frames_dir):
        print(f"{YELLOW}Converting to ASCII...{RESET}")
        os.makedirs(frames_dir, exist_ok=True)
        try:
            subprocess.run(
                ['ffmpeg', '-i', video_path, '-vf', 'fps=5', f'{frames_dir}/frame_%04d.png'],
                capture_output=True,
                timeout=120
            )
        except Exception as e:
            print(f"{RED}Error: {e}{RESET}")
            return

    frames = sorted([f for f in os.listdir(frames_dir) if f.endswith('.png')])
    if not frames:
        print(f"{RED}No frames found{RESET}")
        return

    audio_text = "with audio" if SETTINGS['audio'] else "(muted)"
    print(f"{GREEN}Playing {len(frames)} frames {audio_text}...{RESET}\n")
    print(f"{YELLOW}Controls: SPACE=pause, H/L=skip, Q=quit{RESET}\n")

    PLAYBACK['paused'] = False
    PLAYBACK['skip_frames'] = 0
    PLAYBACK['quit'] = False

    audio_process = None
    if SETTINGS['audio']:
        audio_process = subprocess.Popen(
            ['mpv', '--no-video', video_path],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL
        )

    try:
        frame_duration = 0.2
        start_time = time.time()
        i = 0

        while i < len(frames) and not PLAYBACK['quit']:
            check_input()

            if PLAYBACK['skip_frames'] != 0:
                i = max(0, min(len(frames) - 1, i + PLAYBACK['skip_frames']))
                PLAYBACK['skip_frames'] = 0
                start_time = time.time()

            if PLAYBACK['paused']:
                print(CLEAR, end='')
                print(f"{YELLOW}⏸ PAUSED [space to resume]{RESET}\n")
                while PLAYBACK['paused'] and not PLAYBACK['quit']:
                    check_input()
                    time.sleep(0.1)
                if PLAYBACK['quit']:
                    break
                start_time = time.time()
                continue

            print(CLEAR, end='')
            frame = frames[i]
            frame_path = os.path.join(frames_dir, frame)
            ascii_art = frame_to_ascii(frame_path)
            print(f"[{i+1}/{len(frames)}] SPACE=pause H/L=skip Q=quit")
            print(ascii_art)

            elapsed = time.time() - start_time
            expected_time = (i + 1) * frame_duration
            sleep_time = expected_time - elapsed
            if sleep_time > 0:
                time.sleep(sleep_time)
            i += 1

    except KeyboardInterrupt:
        print(f"\n{YELLOW}Playback stopped{RESET}")
    finally:
        PLAYBACK['quit'] = True
        if audio_process:
            audio_process.terminate()

def play_ascii_video(video):
    """Play video as ASCII art and cache it"""
    url = video.get('url', '')
    title = video.get('title', 'Video')

    if not url:
        print(f"{RED}No URL found{RESET}")
        return

    print(f"\n{GREEN}▶ Downloading: {title}{RESET}\n")

    cache_dir = get_cache_dir()
    video_key = url.split('=')[-1][:11]
    cache_path = os.path.join(cache_dir, video_key)
    os.makedirs(cache_path, exist_ok=True)

    meta_file = os.path.join(cache_path, 'metadata.txt')
    with open(meta_file, 'w') as f:
        f.write(title)

    video_path = os.path.join(cache_path, 'video.mp4')
    frames_dir = os.path.join(cache_path, 'frames')
    os.makedirs(frames_dir, exist_ok=True)

    try:
        result = subprocess.run(
            ['yt-dlp', '-f', 'worst', '-o', video_path, url],
            capture_output=True,
            timeout=60
        )
        if result.returncode != 0:
            print(f"{RED}Download failed{RESET}")
            return
    except Exception as e:
        print(f"{RED}Download error: {e}{RESET}")
        return

