# ANSI color codes
BOLD = '\033[1m'
CYAN = '\033[96m'
GREEN = '\033[92m'
YELLOW = '\033[93m'
RED = '\033[91m'
MAGENTA = '\033[95m'
RESET = '\033[0m'
CLEAR = '\033[2J\033[H'

# ASCII chars
ASCII_CHARS = ['@', '#', 'S', '%', '?', '*', '+', ';', ':', ',', '.']

# Global settings
SETTINGS = {
    'color': True,
    'audio': True,
    'enhance': True,  # Enhance contrast for better text clarity
}

# Playback state
PLAYBACK = {
    'paused': False,
    'skip_frames': 0,
    'quit': False,
}

def enhance_image(image):
    """Enhance contrast and levels for better text clarity"""
    from PIL import ImageEnhance

    # Increase contrast
    enhancer = ImageEnhance.Contrast(image)
    image = enhancer.enhance(1.5)

    # Normalize/equalize
    if image.mode == 'L':
        # For grayscale
        enhancer = ImageEnhance.Brightness(image)
        image = enhancer.enhance(1.1)

    return image

def rgb_to_ansi(r, g, b):
    """Convert RGB to nearest ANSI 256 color"""
    r = int((r / 255) * 5)
    g = int((g / 255) * 5)
    b = int((b / 255) * 5)
    color_code = 16 + (36 * r) + (6 * g) + b
    return f'\033[38;5;{color_code}m'

def check_input():
    """Check if there's keyboard input available"""
    try:
        if select.select([sys.stdin], [], [], 0)[0]:
            ch = sys.stdin.read(1).lower()
            if ch == ' ':
                PLAYBACK['paused'] = not PLAYBACK['paused']
            elif ch == 'l':
                PLAYBACK['skip_frames'] = 5
            elif ch == 'h':
                PLAYBACK['skip_frames'] = -5
            elif ch == 'q':
                PLAYBACK['quit'] = True
            elif ch == 'p':
                PLAYBACK['paused'] = not PLAYBACK['paused']
    except:
        pass

def search_youtube(query):
    """Search YouTube and return results"""
    print(f"\n{YELLOW}🔍 Searching for: {query}{RESET}\n")
    try:
        result = subprocess.run(
            ['yt-dlp', '-j', '--flat-playlist', f'ytsearch10:{query}'],
            capture_output=True,
            text=True,
            timeout=10
        )

        if result.returncode != 0:
            print(f"{RED}Error searching: {result.stderr}{RESET}")
            return []

        videos = []
        for line in result.stdout.strip().split('\n'):
            if line:
                try:
                    videos.append(json.loads(line))
                except json.JSONDecodeError:
                    continue
        return videos
    except Exception as e:
        print(f"{RED}Search failed: {e}{RESET}")
        return []

