    if not videos:
        print(f"{RED}No results found{RESET}")
        return None

    print(f"{BOLD}{CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━{RESET}")
    for i, video in enumerate(videos, 1):
        title = video.get('title', 'Unknown')
        url = video.get('url', '')
        duration = video.get('duration', 0)

        if duration:
            mins, secs = divmod(duration, 60)
            duration_str = f"{int(mins)}:{int(secs):02d}"
        else:
            duration_str = "LIVE"

        print(f"{GREEN}{i:2d}.{RESET} {BOLD}{title[:60]}{RESET}")
        print(f"    {MAGENTA}Duration: {duration_str}{RESET} | {CYAN}{url}{RESET}\n")

    print(f"{BOLD}{CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━{RESET}\n")

    while True:
        try:
            choice = input(f"{YELLOW}Select video (1-{len(videos)}) or 'q' to quit: {RESET}").strip()
            if choice.lower() == 'q':
                return None
            choice = int(choice)
            if 1 <= choice <= len(videos):
                return videos[choice - 1]
            else:
                print(f"{RED}Invalid choice{RESET}")
        except ValueError:
            print(f"{RED}Please enter a number{RESET}")

def get_cache_dir():
    """Get or create cache directory"""
    cache_dir = os.path.expanduser('~/.youtube-ascii-cache')
    os.makedirs(cache_dir, exist_ok=True)
    return cache_dir

def list_cached_videos():
    """List all cached videos"""
    cache_dir = get_cache_dir()
    cached = {}
    for item in os.listdir(cache_dir):
        item_path = os.path.join(cache_dir, item)
        if os.path.isdir(item_path):
            meta_file = os.path.join(item_path, 'metadata.txt')
            if os.path.exists(meta_file):
                with open(meta_file, 'r') as f:
                    title = f.read().strip()
                cached[item] = title
    return cached

